<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controller.ChangePasswordController"
      stylesheets="@styles.css">
    
    <padding>
        <Insets top="30" right="50" bottom="30" left="50"/>
    </padding>
    
    <Label text="تغيير كلمة المرور" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Separator/>
    
    <GridPane hgap="15" vgap="15" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="30"/>
            <ColumnConstraints percentWidth="70"/>
        </columnConstraints>
        
        <Label text="كلمة المرور الحالية:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="currentPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="كلمة المرور الجديدة:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="newPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="تأكيد كلمة المرور:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>
    
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" wrapText="true"/>
    
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="changeButton" text="تغيير كلمة المرور" onAction="#handleChangePassword" styleClass="button-primary"/>
        <Button fx:id="clearButton" text="مسح" onAction="#clearForm" styleClass="button-secondary"/>
    </HBox>
</VBox>