<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CoordinatorDashboardController"
            stylesheets="@styles.css">

    <top>
        <MenuBar>
            <Menu text="File">
                <MenuItem text="Exit" onAction="#handleExit"/>
            </Menu>

            <Menu text="Format">
                <Menu text="Font Size">
                    <MenuItem text="Small" onAction="#changeFontSize"/>
                    <MenuItem text="Medium" onAction="#changeFontSize"/>
                    <MenuItem text="Large" onAction="#changeFontSize"/>
                </Menu>

                <Menu text="Font Family">
                    <MenuItem text="Segoe UI" onAction="#changeFontFamily"/>
                    <MenuItem text="Arial" onAction="#changeFontFamily"/>
                    <MenuItem text="Tahoma" onAction="#changeFontFamily"/>
                </Menu>

                <MenuItem text="Dark Theme" onAction="#changeTheme"/>
            </Menu>

            <Menu text="Help">
                <MenuItem text="About App" onAction="#showAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <left>
        <VBox spacing="10"
              style="-fx-background-color: #2980b9; -fx-padding: 15;"
              prefWidth="220">

            <Label text="GHADS"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Label text="Coordinator Panel"
                   style="-fx-text-fill: #d5f5e3; -fx-font-size: 12px;"/>

            <Separator style="-fx-background-color: #2ecc71;"/>

            <Button text="Dashboard" onAction="#loadDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

            <Button text="Families" onAction="#showFamilies"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

            <Button text="Aid Distribution" onAction="#showAidDistribution"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

            <Separator style="-fx-background-color: #2ecc71;">
                <VBox.margin>
                    <Insets top="10" right="0" bottom="10" left="0"/>
                </VBox.margin>
            </Separator>

            <Button text="Profile" onAction="#showProfile"
                    style="-fx-background-color: transparent; -fx-text-fill: #f9e79f; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

            <Button text="Change Password" onAction="#showChangePassword"
                    style="-fx-background-color: transparent; -fx-text-fill: #f9e79f; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #f1948a; -fx-alignment: CENTER_LEFT; -fx-padding: 12;"/>

        </VBox>
    </left>

    <center>
        <VBox spacing="20"
              style="-fx-background-color: #ecf0f1; -fx-padding: 20;">

            <Label fx:id="welcomeLabel"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e8449;"/>

            <Label fx:id="orgNameLabel"
                   style="-fx-font-size: 14px; -fx-text-fill: #27ae60;"/>

            <!-- إحصائيات Coordinator -->
            <GridPane hgap="15" vgap="15">

                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="0">

                    <Label text="إجمالي العائلات"/>
                    <Label fx:id="totalFamiliesLabel"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0">

                    <Label text="تم خدمتها بواسطة منظمتي"/>
                    <Label fx:id="servedByMyOrgLabel"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;"
                      GridPane.columnIndex="2"
                      GridPane.rowIndex="0">

                    <Label text="لم تتلق مساعدة بعد"/>
                    <Label fx:id="unservedFamiliesLabel"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                </VBox>

            </GridPane>

            <VBox fx:id="contentArea" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

</BorderPane>