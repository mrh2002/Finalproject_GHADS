<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.AdminDashboardController"
            stylesheets="@styles.css">
    
    <top>
        <MenuBar>
            <Menu text="File">
                <MenuItem text="Exit" onAction="#handleExit"/>
            </Menu>
            <Menu text="Format">
                <Menu text="Font Size">
                    <MenuItem text="Small" onAction="#changeFontSize"/>
                    <MenuItem text="Medium" onAction="#changeFontSize"/>
                    <MenuItem text="Large" onAction="#changeFontSize"/>
                </Menu>
                <Menu text="Font Family">
                    <MenuItem text="Segoe UI" onAction="#changeFontFamily"/>
                    <MenuItem text="Arial" onAction="#changeFontFamily"/>
                    <MenuItem text="Tahoma" onAction="#changeFontFamily"/>
                </Menu>
                <MenuItem text="Dark Theme" onAction="#changeTheme"/>
            </Menu>
            <Menu text="Help">
                <MenuItem text="About App" onAction="#showAbout"/>
            </Menu>
        </MenuBar>
    </top>
    
    <left>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;" prefWidth="200">
            <Label text="GHADS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator style="-fx-background-color: #34495e;"/>
            <Button text="Dashboard" onAction="#loadDashboard" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Organizations" onAction="#showOrganizations" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Users" onAction="#showUsers" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Families" onAction="#showFamilies" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Aid Distributions" onAction="#showAidDistributions" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
            <Separator style="-fx-background-color: #34495e;"/>
            <Button text="Change Password" onAction="#showChangePassword" style="-fx-background-color: transparent; -fx-text-fill: #f39c12; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-alignment: CENTER_LEFT;"/>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 20;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <GridPane hgap="15" vgap="15">
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="0">
                    <Label text="Organizations" style="-fx-font-size: 14px;"/>
                    <Label fx:id="totalOrganizationsLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="1">
                    <Label text="Coordinators" style="-fx-font-size: 14px;"/>
                    <Label fx:id="totalCoordinatorsLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="2">
                    <Label text="Families" style="-fx-font-size: 14px;"/>
                    <Label fx:id="totalFamiliesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="3">
                    <Label text="Served" style="-fx-font-size: 14px;"/>
                    <Label fx:id="servedFamiliesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="4">
                    <Label text="Unserved" style="-fx-font-size: 14px;"/>
                    <Label fx:id="unservedFamiliesLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                </VBox>
            </GridPane>
            
            <VBox fx:id="contentArea" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>